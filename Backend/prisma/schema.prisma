generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MaxRedeemMode {
  flat_amount
  percent_of_bill
}



enum GiftCardStatus {
  active
  used
  expired
}

enum PromotionKind {
  cart_percent
  cart_amount
  item_percent
  item_amount
  bogo
  happy_hour_price
}

enum MessageType {
  transaction
  promo
  expiry_warning
  reward
  trial_warning
}

enum MessageChannel {
  sms
  whatsapp
}

enum MessageStatus {
  sent
  failed
}

enum PaymentTenderType {
  cash
  card
  gift_card
  store_credit
  qr
  bank_transfer
  split
  other
}

enum PaymentStatus {
  pending
  authorized
  captured
  refunded
  voided
  failed
}

enum ReceiptEventType {
  printed
  reprinted
  emailed
  viewed
}

enum RefundStatus {
  pending
  completed
  voided
}

enum RefundMethod {
  original_payment
  cash
  card
  store_credit
  gift_card
  other
}

enum ShiftStatus {
  open
  closed
}

enum CashDrawerEventType {
  shift_open
  cash_in
  cash_out
  no_sale
  payout
  shift_close
}

enum StockMovementType {
  sale
  refund
  return
  adjustment
  receiving
  waste
  transfer
  manual
}

enum PurchaseOrderStatus {
  draft
  ordered
  partially_received
  received
  cancelled
}

enum TaxCalculationMode {
  exclusive
  inclusive
}

enum HeldOrderStatus {
  parked
  quote
  layaway
  tab
  converted
  cancelled
}

enum KitchenTicketStatus {
  queued
  preparing
  ready
  completed
  cancelled
}

// ─── Admin Users ─────────────────────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  assignedShops    Shop[]               @relation("PlanAssignedBy")
  featureOverrides ShopFeatureOverride[]
  billingPayments  BillingPayment[]
  planChanges      PlanChangeHistory[]
}

// ─── Plans & Entitlements ────────────────────────────────────────────────────

// id is a human-readable slug: 'basic' | 'standard' | 'pro' | 'enterprise'
model Plan {
  id       String  @id
  name     String
  isActive Boolean @default(true)

  features       PlanFeature[]
  shops          Shop[]              @relation("ShopPlan")
  trialShops     Shop[]              @relation("ShopTrialPlan")
  billingPayments BillingPayment[]
  oldPlanChanges PlanChangeHistory[] @relation("OldPlan")
  newPlanChanges PlanChangeHistory[] @relation("NewPlan")
}

// One row per feature toggle OR limit per plan.
// Feature rows: featureKey set, limitKey null, enabled used.
// Limit rows:   limitKey set, featureKey null, limitValue used (null = unlimited).
model PlanFeature {
  id         String  @id @default(uuid()) @db.Uuid
  planId     String
  featureKey String?
  limitKey   String?
  enabled    Boolean @default(true)
  limitValue Int?

  plan Plan @relation(fields: [planId], references: [id])

  @@unique([planId, featureKey])
  @@unique([planId, limitKey])
}

// ─── Shops ───────────────────────────────────────────────────────────────────

model Shop {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  phone          String?   // Renamed from contactInfo
  email          String    @unique
  planId         String
  planAssignedAt DateTime  @default(now())
  planAssignedBy String?   @db.Uuid
  trialPlanId    String?
  trialExpiresAt DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  plan            Plan       @relation("ShopPlan", fields: [planId], references: [id])
  trialPlan       Plan?      @relation("ShopTrialPlan", fields: [trialPlanId], references: [id])
  assignedByAdmin AdminUser? @relation("PlanAssignedBy", fields: [planAssignedBy], references: [id])

  users             User[]
  customers         Customer[]
  purchases         Purchase[]
  redemptions       Redemption[]
  giftCards         GiftCard[]
  rewards           Reward[]
  productCategories ProductCategory[]
  products          Product[]
  promotions        Promotion[]
  payments          Payment[]
  receipts          Receipt[]
  refunds           Refund[]
  shifts            RegisterShift[]
  cashDrawerEvents  CashDrawerEvent[]
  stockMovements    StockMovement[]
  suppliers         Supplier[]
  purchaseOrders    PurchaseOrder[]
  taxRates          TaxRate[]
  heldOrders        HeldOrder[]
  kitchenTickets    KitchenTicket[]
  rolePermissions   RolePermission[]
  terminals         PosTerminal[]
  productVariants   ProductVariant[]
  modifierGroups    ProductModifierGroup[]
  modifierOptions   ProductModifierOption[]
  settings          ShopSettings?
  featureOverrides  ShopFeatureOverride[]
  billingPayments   BillingPayment[]
  planChangeHistory PlanChangeHistory[]
  auditLogs         AuditLog[]
  messageLogs       MessageLog[]
}

model ShopFeatureOverride {
  id         String   @id @default(uuid()) @db.Uuid
  shopId     String   @db.Uuid
  featureKey String?
  limitKey   String?
  enabled    Boolean  @default(true)
  limitValue Int?
  reason     String
  createdBy  String   @db.Uuid
  createdAt  DateTime @default(now())

  shop  Shop      @relation(fields: [shopId], references: [id])
  admin AdminUser @relation(fields: [createdBy], references: [id])

  @@index([shopId])
}

model ShopSettings {
  shopId             String         @id @db.Uuid
  pointsPerAmount    Decimal        @default(100) @db.Decimal(10, 2)
  redemptionValue    Decimal        @default(500) @db.Decimal(10, 2)
  minRedeemPoints    Int            @default(0)
  maxRedeemMode      MaxRedeemMode  @default(flat_amount)
  pointsExpiryMonths Int            @default(0)
  expiryWarningDays  Int            @default(14)

  shop Shop @relation(fields: [shopId], references: [id])
}

// Products (POS)
model ProductCategory {
  id          String   @id @default(uuid()) @db.Uuid
  shopId      String   @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now())

  shop     Shop     @relation(fields: [shopId], references: [id])
  products Product[]

  @@unique([shopId, name])
  @@index([shopId, name])
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  shopId         String   @db.Uuid
  categoryId     String?  @db.Uuid
  name           String
  sku            String
  barcode        String?
  description    String?
  imageUrl       String?
  unit           String?
  price          Decimal  @db.Decimal(12, 2)
  cost           Decimal? @db.Decimal(12, 2)
  taxRate        Decimal? @db.Decimal(5, 2)
  taxRateId      String?  @db.Uuid
  taxMode        TaxCalculationMode @default(exclusive)
  trackInventory Boolean  @default(true)
  stockOnHand    Int      @default(0)
  reorderLevel   Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  shop     Shop             @relation(fields: [shopId], references: [id])
  category ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  taxCode  TaxRate?         @relation(fields: [taxRateId], references: [id], onDelete: SetNull)
  purchaseItems PurchaseItem[]
  variants ProductVariant[]
  modifierGroups ProductModifierGroup[]
  stockMovements StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  refundItems RefundItem[]

  @@unique([shopId, sku])
  @@unique([shopId, barcode])
  @@index([shopId, name])
  @@index([shopId, categoryId])
  @@index([shopId, taxRateId])
  @@index([shopId, deletedAt])
}

model ProductVariant {
  id             String   @id @default(uuid()) @db.Uuid
  shopId         String   @db.Uuid
  productId      String   @db.Uuid
  name           String
  sku            String
  barcode        String?
  price          Decimal? @db.Decimal(12, 2)
  cost           Decimal? @db.Decimal(12, 2)
  stockOnHand    Int      @default(0)
  reorderLevel   Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  shop     Shop    @relation(fields: [shopId], references: [id])
  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseItems PurchaseItem[]
  stockMovements StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  refundItems RefundItem[]

  @@unique([shopId, sku])
  @@unique([shopId, barcode])
  @@index([shopId, productId])
}

model ProductModifierGroup {
  id         String   @id @default(uuid()) @db.Uuid
  shopId     String   @db.Uuid
  productId  String   @db.Uuid
  name       String
  minSelect  Int      @default(0)
  maxSelect  Int      @default(1)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  shop    Shop    @relation(fields: [shopId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  options ProductModifierOption[]

  @@index([shopId, productId])
}

model ProductModifierOption {
  id        String   @id @default(uuid()) @db.Uuid
  shopId    String   @db.Uuid
  groupId   String   @db.Uuid
  name      String
  priceDelta Decimal @default(0) @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  shop  Shop @relation(fields: [shopId], references: [id])
  group ProductModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([shopId, groupId])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  shopId              String    @db.Uuid
  name                String
  username            String    @unique // Unique identifier for staff login
  passwordHash        String
  isActive            Boolean   @default(true)
  forcePasswordChange Boolean   @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())

  shop             Shop         @relation(fields: [shopId], references: [id])
  purchases        Purchase[]   @relation("PurchaseRecordedBy")
  purchasesVoided  Purchase[]   @relation("PurchaseVoidedBy")
  payments         Payment[]    @relation("PaymentRecordedBy")
  refunds          Refund[]     @relation("RefundRecordedBy")
  shifts           RegisterShift[]
  cashDrawerEvents CashDrawerEvent[]
  stockMovements   StockMovement[]
  heldOrders       HeldOrder[]
  kitchenTickets   KitchenTicket[]
  redemptions      Redemption[] @relation("RedemptionUser")
  redemptionsVoided Redemption[] @relation("RedemptionVoidedBy")
  giftCardsCreated GiftCard[]   @relation("GiftCardCreatedBy")
  giftCardsUsed    GiftCard[]   @relation("GiftCardUsedBy")
  auditLogs        AuditLog[]
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id             String    @id @default(uuid()) @db.Uuid
  shopId         String    @db.Uuid
  name           String
  phone          String
  totalPoints    Int       @default(0)
  lastActivityAt DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  shop        Shop         @relation(fields: [shopId], references: [id])
  purchases   Purchase[]
  redemptions Redemption[]
  messageLogs MessageLog[]

  @@unique([shopId, phone])
  @@index([shopId, phone])
  @@index([shopId, lastActivityAt])
  @@index([shopId, deletedAt])
}

// ─── Purchases ───────────────────────────────────────────────────────────────

model Purchase {
  id           String    @id @default(uuid()) @db.Uuid
  shopId       String    @db.Uuid
  customerId   String    @db.Uuid
  userId       String    @db.Uuid
  subtotal     Decimal   @default(0) @db.Decimal(12, 2)
  discountTotal Decimal  @default(0) @db.Decimal(12, 2)
  taxTotal     Decimal   @default(0) @db.Decimal(12, 2)
  serviceCharge Decimal  @default(0) @db.Decimal(12, 2)
  amount       Decimal   @db.Decimal(12, 2)
  pointsEarned Int       @default(0)
  receiptNumber String?
  paymentStatus PaymentStatus @default(pending)
  terminalId    String?   @db.Uuid
  shiftId       String?   @db.Uuid
  heldOrderId   String?   @db.Uuid
  isVoided     Boolean   @default(false)
  voidedBy     String?   @db.Uuid
  voidedAt     DateTime?
  createdAt    DateTime  @default(now())

  shop         Shop     @relation(fields: [shopId], references: [id])
  customer     Customer @relation(fields: [customerId], references: [id])
  user         User     @relation("PurchaseRecordedBy", fields: [userId], references: [id])
  voidedByUser User?    @relation("PurchaseVoidedBy", fields: [voidedBy], references: [id])
  terminal     PosTerminal? @relation(fields: [terminalId], references: [id], onDelete: SetNull)
  shift        RegisterShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  heldOrder    HeldOrder? @relation(fields: [heldOrderId], references: [id], onDelete: SetNull)
  items        PurchaseItem[]
  promotions   PurchasePromotion[]
  payments     Payment[]
  receipts     Receipt[]
  refunds      Refund[]
  stockMovements StockMovement[]
  kitchenTickets KitchenTicket[]

  @@index([shopId, customerId, createdAt(sort: Desc)])
  @@index([shopId, createdAt(sort: Desc)])
  @@unique([shopId, receiptNumber])
  @@index([shopId, shiftId])
}

model PurchaseItem {
  id         String   @id @default(uuid()) @db.Uuid
  purchaseId String   @db.Uuid
  productId  String?  @db.Uuid
  variantId  String?  @db.Uuid
  name       String
  sku        String?
  originalUnitPrice Decimal? @db.Decimal(12, 2)
  unitPrice  Decimal  @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  taxRate    Decimal? @db.Decimal(5, 2)
  taxAmount  Decimal  @default(0) @db.Decimal(12, 2)
  finalUnitPrice Decimal? @db.Decimal(12, 2)
  quantity   Int
  lineTotal  Decimal  @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([productId])
  @@index([variantId])
}

model Promotion {
  id               String        @id @default(uuid()) @db.Uuid
  shopId           String        @db.Uuid
  name             String
  description      String?
  kind             PromotionKind
  isActive         Boolean       @default(true)
  priority         Int           @default(100)
  stackable        Boolean       @default(false)
  startAt          DateTime?
  endAt            DateTime?
  daysOfWeek       Int[]         @default([])
  startTime        String?       // "HH:MM"
  endTime          String?       // "HH:MM"
  couponCode       String?
  usageLimit       Int?
  perCustomerLimit Int?
  usedCount        Int           @default(0)
  config           Json
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  shop Shop @relation(fields: [shopId], references: [id])
  appliedPurchases PurchasePromotion[]

  @@index([shopId, isActive])
  @@index([shopId, kind])
  @@index([shopId, deletedAt])
  @@unique([shopId, couponCode])
}

model PurchasePromotion {
  id              String        @id @default(uuid()) @db.Uuid
  purchaseId      String        @db.Uuid
  promotionId     String?       @db.Uuid
  nameSnapshot    String
  kindSnapshot    PromotionKind
  couponCode      String?
  discountAmount  Decimal       @db.Decimal(12, 2)
  details         Json?
  createdAt       DateTime      @default(now())

  purchase  Purchase   @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  promotion Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([promotionId])
}

model Payment {
  id          String            @id @default(uuid()) @db.Uuid
  shopId      String            @db.Uuid
  purchaseId  String?           @db.Uuid
  refundId    String?           @db.Uuid
  shiftId     String?           @db.Uuid
  userId      String            @db.Uuid
  tenderType  PaymentTenderType
  amount      Decimal           @db.Decimal(12, 2)
  reference   String?
  status      PaymentStatus     @default(captured)
  terminalId  String?           @db.Uuid
  metadata    Json?
  capturedAt  DateTime?
  createdAt   DateTime          @default(now())

  shop     Shop       @relation(fields: [shopId], references: [id])
  purchase Purchase?  @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  refund   Refund?    @relation(fields: [refundId], references: [id], onDelete: SetNull)
  shift    RegisterShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  user     User       @relation("PaymentRecordedBy", fields: [userId], references: [id])
  terminal PosTerminal? @relation(fields: [terminalId], references: [id], onDelete: SetNull)

  @@index([shopId, purchaseId])
  @@index([shopId, refundId])
  @@index([shopId, shiftId])
  @@index([shopId, createdAt])
}

model ReceiptSequence {
  shopId       String   @id @db.Uuid
  prefix       String   @default("INV")
  nextNumber   Int      @default(1)
  padding      Int      @default(6)
  updatedAt    DateTime @updatedAt
}

model Receipt {
  id              String   @id @default(uuid()) @db.Uuid
  shopId          String   @db.Uuid
  purchaseId      String   @db.Uuid
  receiptNumber   String
  businessName    String?
  businessTaxId   String?
  templateVersion String   @default("standard-v1")
  subtotal        Decimal  @default(0) @db.Decimal(12, 2)
  discountTotal   Decimal  @default(0) @db.Decimal(12, 2)
  taxTotal        Decimal  @default(0) @db.Decimal(12, 2)
  serviceCharge   Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  reprintCount    Int      @default(0)
  createdAt       DateTime @default(now())

  shop     Shop     @relation(fields: [shopId], references: [id])
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  events   ReceiptEvent[]

  @@unique([shopId, receiptNumber])
  @@index([shopId, purchaseId])
}

model ReceiptEvent {
  id         String           @id @default(uuid()) @db.Uuid
  receiptId  String           @db.Uuid
  eventType  ReceiptEventType
  userId     String?          @db.Uuid
  terminalId String?          @db.Uuid
  createdAt  DateTime         @default(now())

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
}

model Refund {
  id                String       @id @default(uuid()) @db.Uuid
  shopId            String       @db.Uuid
  purchaseId        String       @db.Uuid
  userId            String       @db.Uuid
  refundNumber      String?
  method            RefundMethod @default(original_payment)
  reason            String
  subtotal          Decimal      @default(0) @db.Decimal(12, 2)
  taxTotal          Decimal      @default(0) @db.Decimal(12, 2)
  amount            Decimal      @db.Decimal(12, 2)
  status            RefundStatus @default(completed)
  managerApprovedBy String?      @db.Uuid
  createdAt         DateTime     @default(now())
  voidedAt          DateTime?

  shop     Shop     @relation(fields: [shopId], references: [id])
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  user     User     @relation("RefundRecordedBy", fields: [userId], references: [id])
  items    RefundItem[]
  payments Payment[]
  stockMovements StockMovement[]

  @@unique([shopId, refundNumber])
  @@index([shopId, purchaseId])
  @@index([shopId, createdAt])
}

model RefundItem {
  id             String  @id @default(uuid()) @db.Uuid
  refundId       String  @db.Uuid
  purchaseItemId String? @db.Uuid
  productId      String? @db.Uuid
  variantId      String? @db.Uuid
  name           String
  quantity       Int
  unitPrice      Decimal @db.Decimal(12, 2)
  taxAmount      Decimal @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal @db.Decimal(12, 2)

  refund  Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([refundId])
  @@index([productId])
}

model RegisterShift {
  id           String      @id @default(uuid()) @db.Uuid
  shopId       String      @db.Uuid
  userId       String      @db.Uuid
  terminalId   String?     @db.Uuid
  status       ShiftStatus @default(open)
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  openingCash  Decimal     @default(0) @db.Decimal(12, 2)
  cashIn       Decimal     @default(0) @db.Decimal(12, 2)
  cashOut      Decimal     @default(0) @db.Decimal(12, 2)
  expectedCash Decimal     @default(0) @db.Decimal(12, 2)
  closingCash  Decimal?    @db.Decimal(12, 2)
  variance     Decimal?    @db.Decimal(12, 2)
  note         String?

  shop     Shop @relation(fields: [shopId], references: [id])
  user     User @relation(fields: [userId], references: [id])
  terminal PosTerminal? @relation(fields: [terminalId], references: [id], onDelete: SetNull)
  payments Payment[]
  purchases Purchase[]
  cashDrawerEvents CashDrawerEvent[]

  @@index([shopId, userId, status])
  @@index([shopId, openedAt])
}

model CashDrawerEvent {
  id         String              @id @default(uuid()) @db.Uuid
  shopId     String              @db.Uuid
  shiftId    String              @db.Uuid
  userId     String              @db.Uuid
  terminalId String?             @db.Uuid
  eventType  CashDrawerEventType
  amount     Decimal             @default(0) @db.Decimal(12, 2)
  reason     String?
  createdAt  DateTime            @default(now())

  shop     Shop @relation(fields: [shopId], references: [id])
  shift    RegisterShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user     User @relation(fields: [userId], references: [id])
  terminal PosTerminal? @relation(fields: [terminalId], references: [id], onDelete: SetNull)

  @@index([shopId, shiftId])
}

model StockMovement {
  id              String            @id @default(uuid()) @db.Uuid
  shopId          String            @db.Uuid
  productId       String?           @db.Uuid
  variantId       String?           @db.Uuid
  purchaseId      String?           @db.Uuid
  refundId        String?           @db.Uuid
  supplierId      String?           @db.Uuid
  purchaseOrderId String?           @db.Uuid
  userId          String?           @db.Uuid
  movementType    StockMovementType
  quantityDelta   Int
  stockBefore     Int
  stockAfter      Int
  unitCost        Decimal?          @db.Decimal(12, 2)
  reason          String?
  createdAt       DateTime          @default(now())

  shop     Shop @relation(fields: [shopId], references: [id])
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  purchase Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  refund   Refund? @relation(fields: [refundId], references: [id], onDelete: SetNull)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  user     User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([shopId, productId, createdAt])
  @@index([shopId, variantId, createdAt])
}

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  shopId    String   @db.Uuid
  name      String
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
  purchaseOrders PurchaseOrder[]
  stockMovements StockMovement[]

  @@unique([shopId, name])
  @@index([shopId, isActive])
}

model PurchaseOrder {
  id          String              @id @default(uuid()) @db.Uuid
  shopId      String              @db.Uuid
  supplierId  String?             @db.Uuid
  orderNumber String
  status      PurchaseOrderStatus @default(draft)
  expectedAt  DateTime?
  receivedAt  DateTime?
  subtotal    Decimal             @default(0) @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  shop     Shop @relation(fields: [shopId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    PurchaseOrderItem[]
  stockMovements StockMovement[]

  @@unique([shopId, orderNumber])
  @@index([shopId, status])
}

model PurchaseOrderItem {
  id                String @id @default(uuid()) @db.Uuid
  purchaseOrderId   String @db.Uuid
  productId         String @db.Uuid
  variantId         String? @db.Uuid
  quantityOrdered   Int
  quantityReceived  Int @default(0)
  unitCost          Decimal @default(0) @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([productId])
}

model TaxRate {
  id        String   @id @default(uuid()) @db.Uuid
  shopId    String   @db.Uuid
  name      String
  rate      Decimal  @db.Decimal(5, 2)
  mode      TaxCalculationMode @default(exclusive)
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop     Shop @relation(fields: [shopId], references: [id])
  products Product[]

  @@unique([shopId, name])
  @@index([shopId, isActive])
}

model HeldOrder {
  id                  String          @id @default(uuid()) @db.Uuid
  shopId              String          @db.Uuid
  userId              String          @db.Uuid
  customerId          String?         @db.Uuid
  status              HeldOrderStatus @default(parked)
  label               String?
  cart                Json
  subtotal            Decimal         @default(0) @db.Decimal(12, 2)
  expiresAt           DateTime?
  convertedPurchaseId String?         @db.Uuid
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
  user User @relation(fields: [userId], references: [id])
  purchases Purchase[]

  @@index([shopId, status, createdAt])
}

model KitchenTicket {
  id           String              @id @default(uuid()) @db.Uuid
  shopId       String              @db.Uuid
  purchaseId   String?             @db.Uuid
  userId       String              @db.Uuid
  ticketNumber String
  status       KitchenTicketStatus @default(queued)
  items        Json
  note         String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  user User @relation(fields: [userId], references: [id])

  @@unique([shopId, ticketNumber])
  @@index([shopId, status])
}

model PosTerminal {
  id        String   @id @default(uuid()) @db.Uuid
  shopId    String   @db.Uuid
  name      String
  code      String
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
  purchases Purchase[]
  payments Payment[]
  shifts RegisterShift[]
  cashDrawerEvents CashDrawerEvent[]

  @@unique([shopId, code])
}

model RolePermission {
  id            String  @id @default(uuid()) @db.Uuid
  shopId        String  @db.Uuid
  role          String
  permissionKey String
  enabled       Boolean @default(true)

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, role, permissionKey])
  @@index([shopId, role])
}

// ─── Redemptions ─────────────────────────────────────────────────────────────

model Redemption {
  id             String    @id @default(uuid()) @db.Uuid
  shopId         String    @db.Uuid
  customerId     String    @db.Uuid
  userId         String    @db.Uuid
  pointsRedeemed Int
  discountValue  Decimal   @db.Decimal(12, 2)
  notes          String?
  isVoided       Boolean   @default(false)
  voidedBy       String?   @db.Uuid
  voidedAt       DateTime?
  createdAt      DateTime  @default(now())

  shop         Shop     @relation(fields: [shopId], references: [id])
  customer     Customer @relation(fields: [customerId], references: [id])
  user         User     @relation("RedemptionUser", fields: [userId], references: [id])
  voidedByUser User?    @relation("RedemptionVoidedBy", fields: [voidedBy], references: [id])

  @@index([shopId, customerId])
  @@index([shopId, createdAt(sort: Desc)])
}

// ─── Gift Cards ───────────────────────────────────────────────────────────────

model GiftCard {
  id         String         @id @default(uuid()) @db.Uuid
  shopId     String         @db.Uuid
  code       String         @unique
  value      Decimal        @db.Decimal(12, 2)
  status     GiftCardStatus @default(active)
  expiryDate DateTime?      @db.Date
  usedAt     DateTime?
  usedBy     String?        @db.Uuid
  createdBy  String         @db.Uuid
  createdAt  DateTime       @default(now())
  deletedAt  DateTime?

  shop          Shop  @relation(fields: [shopId], references: [id])
  usedByUser    User? @relation("GiftCardUsedBy", fields: [usedBy], references: [id])
  createdByUser User  @relation("GiftCardCreatedBy", fields: [createdBy], references: [id])

  @@index([shopId, status])
}

// ─── Rewards (Milestone Config) ──────────────────────────────────────────────

model Reward {
  id                String  @id @default(uuid()) @db.Uuid
  shopId            String  @db.Uuid
  pointsRequired    Int
  rewardDescription String
  isActive          Boolean @default(true)

  shop Shop @relation(fields: [shopId], references: [id])
}

// ─── Billing ─────────────────────────────────────────────────────────────────

model BillingPayment {
  id          String   @id @default(uuid()) @db.Uuid
  shopId      String   @db.Uuid
  planId      String
  amount      Decimal  @db.Decimal(12, 2)
  periodMonth Int
  periodYear  Int
  paidOn      DateTime @db.Date
  recordedBy  String   @db.Uuid
  notes       String?
  createdAt   DateTime @default(now())

  shop  Shop      @relation(fields: [shopId], references: [id])
  plan  Plan      @relation(fields: [planId], references: [id])
  admin AdminUser @relation(fields: [recordedBy], references: [id])
}

model PlanChangeHistory {
  id        String   @id @default(uuid()) @db.Uuid
  shopId    String   @db.Uuid
  oldPlanId String
  newPlanId String
  changedBy String   @db.Uuid
  note      String?
  createdAt DateTime @default(now())

  shop    Shop      @relation(fields: [shopId], references: [id])
  oldPlan Plan      @relation("OldPlan", fields: [oldPlanId], references: [id])
  newPlan Plan      @relation("NewPlan", fields: [newPlanId], references: [id])
  admin   AdminUser @relation(fields: [changedBy], references: [id])
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  shopId     String?  @db.Uuid
  userId     String?  @db.Uuid
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  shop Shop? @relation(fields: [shopId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@index([shopId, createdAt(sort: Desc)])
}

// ─── Message Log ─────────────────────────────────────────────────────────────

model MessageLog {
  id          String         @id @default(uuid()) @db.Uuid
  shopId      String         @db.Uuid
  customerId  String?        @db.Uuid
  phone       String
  messageType MessageType
  channel     MessageChannel @default(sms)
  content     String
  status      MessageStatus  @default(sent)
  createdAt   DateTime       @default(now())

  shop     Shop      @relation(fields: [shopId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([shopId, createdAt(sort: Desc)])
}
