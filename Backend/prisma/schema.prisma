generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Plans & Entitlements ────────────────────────────────────────────────────

model Plan {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  description   String?
  priceMonthly  Decimal?      @db.Decimal(10, 2)
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  features      PlanFeature[]
  limits        PlanLimit[]
  subscriptions Subscription[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model PlanFeature {
  id         String @id @default(cuid())
  planId     String
  featureKey String
  plan       Plan   @relation(fields: [planId], references: [id])

  @@unique([planId, featureKey])
}

model PlanLimit {
  id       String @id @default(cuid())
  planId   String
  limitKey String
  value    Int    // -1 = unlimited
  plan     Plan   @relation(fields: [planId], references: [id])

  @@unique([planId, limitKey])
}

// ─── Shops & Users ───────────────────────────────────────────────────────────

model Shop {
  id               String                @id @default(cuid())
  name             String
  isActive         Boolean               @default(true)
  usageWarningAt   DateTime?
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  users            User[]
  customers        Customer[]
  purchases        Purchase[]
  redemptions      Redemption[]
  giftCards        GiftCard[]
  rewards          Reward[]
  campaigns        MessagingCampaign[]
  settings         ShopSettings?
  subscription     Subscription?
  customerPoints   CustomerPoints[]
  entitlementOverrides EntitlementOverride[]
  billingRecords   BillingRecord[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  role         String   @default("staff") // admin | owner | staff
  shopId       String?
  isActive     Boolean  @default(true)
  shop         Shop?    @relation(fields: [shopId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Subscription {
  id               String    @id @default(cuid())
  shopId           String    @unique
  planId           String?
  isTrial          Boolean   @default(false)
  trialEndsAt      DateTime?
  trialWarningSent Boolean   @default(false)
  shop             Shop      @relation(fields: [shopId], references: [id])
  plan             Plan?     @relation(fields: [planId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model EntitlementOverride {
  id         String  @id @default(cuid())
  shopId     String
  featureKey String?
  limitKey   String?
  enabled    Boolean @default(true)
  value      Int?
  shop       Shop    @relation(fields: [shopId], references: [id])
}

// ─── Customers & Points ──────────────────────────────────────────────────────

model Customer {
  id          String          @id @default(cuid())
  shopId      String
  name        String
  phone       String
  email       String?
  birthday    DateTime?
  notes       String?
  shop        Shop            @relation(fields: [shopId], references: [id])
  points      CustomerPoints?
  purchases   Purchase[]
  redemptions Redemption[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([shopId, phone])
}

model CustomerPoints {
  id          String    @id @default(cuid())
  customerId  String    @unique
  shopId      String
  points      Int       @default(0)
  expiresAt   DateTime?
  warningSent Boolean   @default(false)
  customer    Customer  @relation(fields: [customerId], references: [id])
  shop        Shop      @relation(fields: [shopId], references: [id])
  updatedAt   DateTime  @updatedAt
}

// ─── Purchases & Redemptions ─────────────────────────────────────────────────

model Purchase {
  id           String   @id @default(cuid())
  shopId       String
  customerId   String
  amount       Decimal  @db.Decimal(12, 2)
  pointsEarned Int      @default(0)
  reference    String?
  notes        String?
  shop         Shop     @relation(fields: [shopId], references: [id])
  customer     Customer @relation(fields: [customerId], references: [id])
  createdAt    DateTime @default(now())
}

model Redemption {
  id          String   @id @default(cuid())
  shopId      String
  customerId  String
  rewardId    String
  pointsSpent Int
  notes       String?
  shop        Shop     @relation(fields: [shopId], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])
  reward      Reward   @relation(fields: [rewardId], references: [id])
  createdAt   DateTime @default(now())
}

// ─── Rewards & Gift Cards ────────────────────────────────────────────────────

model Reward {
  id          String       @id @default(cuid())
  shopId      String
  name        String
  description String?
  pointsCost  Int
  isActive    Boolean      @default(true)
  shop        Shop         @relation(fields: [shopId], references: [id])
  redemptions Redemption[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model GiftCard {
  id              String    @id @default(cuid())
  shopId          String
  code            String
  initialBalance  Decimal   @db.Decimal(12, 2)
  balance         Decimal   @db.Decimal(12, 2)
  status          String    @default("ACTIVE") // ACTIVE | USED | EXPIRED | DISABLED
  expiresAt       DateTime?
  recipientName   String?
  recipientPhone  String?
  notes           String?
  shop            Shop      @relation(fields: [shopId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([shopId, code])
}

// ─── Messaging ───────────────────────────────────────────────────────────────

model MessagingCampaign {
  id             String    @id @default(cuid())
  shopId         String
  message        String
  recipientType  String    // all | segment | individual
  recipientCount Int       @default(0)
  sentCount      Int       @default(0)
  failedCount    Int       @default(0)
  status         String    @default("DRAFT") // DRAFT | SENDING | SENT | SCHEDULED | FAILED
  scheduledAt    DateTime?
  shop           Shop      @relation(fields: [shopId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Settings ────────────────────────────────────────────────────────────────

model ShopSettings {
  id                    String   @id @default(cuid())
  shopId                String   @unique
  pointsPerCurrencyUnit Float    @default(1)
  pointsExpiryDays      Int      @default(0) // 0 = never
  smsApiKeyEncrypted    String?
  smsSenderId           String?
  welcomeMessage        String?
  birthdayMessage       String?
  timezone              String   @default("Asia/Colombo")
  shop                  Shop     @relation(fields: [shopId], references: [id])
  updatedAt             DateTime @updatedAt
}

// ─── Billing ─────────────────────────────────────────────────────────────────

model BillingRecord {
  id          String   @id @default(cuid())
  shopId      String
  planId      String?
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("LKR")
  status      String   @default("PENDING") // PENDING | PAID | FAILED | REFUNDED
  reference   String?
  notes       String?
  shop        Shop     @relation(fields: [shopId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
