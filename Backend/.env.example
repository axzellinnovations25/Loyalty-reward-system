# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/loyalty_db

# Auth
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# Encryption (AES-256 — must be exactly 32 chars)
ENCRYPTION_KEY=your-32-character-encryption-key!

# AWS Secrets Manager (production only)
AWS_REGION=ap-southeast-1
AWS_SECRET_NAME=loyalty/production

# SMS — text.lk
SMS_API_URL=https://app.text.lk/api/v3/sms/send
